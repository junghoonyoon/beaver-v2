artSec": 5.2, "text": "오십시오. 안녕하세요. 안녕하십니까."}, {"startSec": 6.759, "text": "WM센터 손수현입니다.네"}, {"startSec": 8.519, "text": "&gt;&gt; 반갑습니다. 어쩜 이렇게 큐티할 수"}, {"startSec": 11.799, "text": "있을까요?"}, {"startSec": 12.519, "text": "&gt;&gt; 큐티가 뭐죠?"}, {"startSec": 14.519, "text": "&gt;&gt; 귀염 귀염."}, {"startSec": 15.44, "text": "&gt;&gt; 아네 좋습니다. 우리 선수현 PV 님"}, {"startSec": 18.0, "text": "용산에서 오셨고요.네"}, {"startSec": 19.32, "text": "&gt;&gt; 맞습니다."}, {"startSec": 19.8, "text": "&gt;&gt; 오늘이 그날이잖아요. 사실 이벤트"}, {"startSec": 21.519, "text": "하시는 날."}, {"startSec": 22.119, "text": "&gt;&gt; 아 맞습니다. 세미나 여는 날이라서"}, {"startSec": 24.199, "text": "목요일에도 한번 방문을 해 봤습니다."}, {"startSec": 26.48, "text": "&gt;&gt; 그 오늘 오늘 연극하는 날인데 왜 온"}, {"startSec": 28.8, "text": "거예요?"}, {"startSec": 29.599, "text": "아, 이제 오늘 마이크론 실적도"}, {"startSec": 31.8, "text": "좋았고 아무래도 이제 마감으로 알고"}, {"startSec": 34.52, "text": "계신 분들 있으신데 아무래도 저희가"}, {"startSec": 36.879, "text": "반도체를 많이 담은 지점이기도 해서"}, {"startSec": 39.8, "text": "조금 더"}, {"startSec": 40.76, "text": "&gt;&gt; 추가적으로 이야기를 드려 보려고 좀"}, {"startSec": 43.719, "text": "&gt;&gt; 아, 그렇게 마음대로 되나?"}, {"startSec": 46.0, "text": "&gt;&gt; 네. 어 그래요."}, {"startSec": 47.76, "text": "&gt;&gt; 좋습니다. 하여튼 뭐 우리 손수현"}, {"startSec": 49.84, "text": "PV 님 그 반도체는"}, {"startSec": 53.28, "text": "저희가 뭐 계속해서 지금 시장에서 뭐"}, {"startSec": 56.359, "text": "역시 주인공이고 앞으로도 상당 기간은"}, {"startSec": 59.0, "text": "그럴 건데 그중에 이제 우리 반도체"}, {"startSec": 62.12, "text": "우리 하이닉스 삼성전자를 가장 이제"}, {"startSec": 65.68, "text": "잘 미래를 보여 줄 우리 마이크론"}, {"startSec": 68.0, "text": "실적이 이제 새벽에 나왔고"}, {"startSec": 69.56, "text": "&gt;&gt; 네"}, {"startSec": 70.24, "text": "&gt;&gt; 아 그래서 이제 주가가"}, {"startSec": 72.72, "text": "&gt;&gt; 많이 갔죠."}, {"startSec": 73.6, "text": "&gt;&gt; 네. 많이 올랐죠. 한 10%대 상승"}, {"startSec": 75.92, "text": "시간에 의해서 올랐고 해가지고 네"}, {"startSec": 78.56, "text": "&gt;&gt; 뭐 저는 국장도 오늘"}, {"startSec": 80.68, "text": "&gt;&gt; 더 좋을 거라고 생각하고 장기적으로도"}, {"startSec": 82.72, "text": "더 긍정적으로 보고 있습니다."}, {"startSec": 84.72, "text": "&gt;&gt; 아 알겠습니다. 그럼 뭐 마이크는"}, {"startSec": 88.2, "text": "실적 뭐 잠깐만 그럼 한번 확인해"}, {"startSec": 90.88, "text": "볼까요?"}, {"startSec": 91.4, "text": "&gt;&gt; 네. 네."}, {"startSec": 92.64, "text": "&gt;&gt; 뭐 간단하게 보겠습니다. 다른 분들도"}, {"startSec": 95.079, "text": "워낙 말씀 많이 주셔 가지고 장표"}, {"startSec": 97.32, "text": "간단하게 보면"}, {"startSec": 98.32, "text": "&gt;&gt; 네."}, {"startSec": 98.84, "text": "&gt;&gt; 일단 월요일 양봉업자가 목요일에 와"}, {"startSec": 101.72, "text": "봤는데 오늘도 역시 좋아서"}, {"startSec": 103.36, "text": "다행이네요. 그래서 이제 마이크론"}, {"startSec": 105.84, "text": "러닝 서프라이즈 났고 그다음에 AD"}, {"startSec": 108.32, "text": "할 건 있어 가지고 좀 네. 좋을 것"}, {"startSec": 111.479, "text": "같습니다. 그래서 마이크론 실적 발표"}, {"startSec": 113.52, "text": "이제 제가 생각했을 땐 에루샤보다"}, {"startSec": 116.0, "text": "전마다."}, {"startSec": 117.439, "text": "&gt;&gt; 왜냐면 이게 어떤 느낌이냐면 이제"}, {"startSec": 120.84, "text": "마진이 86%까지 날려면 그냥 럭셔리"}, {"startSec": 124.6, "text": "브랜드 이상의 가치인 거거든요."}, {"startSec": 127.24, "text": "&gt;&gt; 네."}, {"startSec": 127.479, "text": "&gt;&gt; 그러니까 뭐 에르메스 샤넬 요런"}, {"startSec": 129.28, "text": "것들도 마진이 한 70%밖에 안"}, {"startSec": 131.44, "text": "나와요."}, {"startSec": 132.48, "text": "&gt;&gt; 70%밖에 안 나와요."}, {"startSec": 133.8, "text": "&gt;&gt; 네. 근데 이제 이걸 이겨낸 이제"}, {"startSec": 137.48, "text": "마이크론이 있으니까"}, {"startSec": 139.16, "text": "&gt;&gt; 이게 3위의 기세라면 이제 전자"}, {"startSec": 142.08, "text": "닉스는 이번 7월 실적 발표에서 더"}, {"startSec": 145.08, "text": "기대감을 가지고 봐도 되지 않을까라는"}, {"startSec": 147.84, "text": "생각을 가지고 있습니다."}, {"startSec": 150.04, "text": "&gt;&gt; 그러니까요. 기대감이 자시 마진에"}, {"startSec": 152.12, "text": "대해서 이제 사람들이 한 2주 동안"}, {"startSec": 154.2, "text": "집중할 것 같은데"}, {"startSec": 155.959, "text": "&gt;&gt; 삼성자와 SK닉스가 HBM 시장을"}, {"startSec": 158.519, "text": "바라보는 행태 변화가 좀 있다라는게"}, {"startSec": 160.36, "text": "회사 보고서들의"}, {"startSec": 161.68, "text": "&gt;&gt; 어 분석이잖아요. 네 삼성전자는"}, {"startSec": 163.4, "text": "HBM 4로 간다."}, {"startSec": 165.2, "text": "&gt;&gt; 네."}, {"startSec": 165.64, "text": "&gt;&gt; 어 SK닉스는 HBM에 주목하면서"}, {"startSec": 168.28, "text": "집중하면서 좀 더 영업 이익률가"}, {"startSec": 170.159, "text": "마진을 높인다."}, {"startSec": 171.84, "text": "&gt;&gt; 어 시장이 어떻게 결론낼지 좀"}, {"startSec": 173.8, "text": "궁금한데"}, {"startSec": 175.319, "text": "오늘 전반적으로 고객들 모시고 손님들"}, {"startSec": 177.56, "text": "모시고 그럼 뭐 말씀 주시는 거예요?"}, {"startSec": 180.04, "text": "우선 저희가 뭐 김지현 센터장님도"}, {"startSec": 183.0, "text": "그렇고 이전부터 계속 반도체를"}, {"startSec": 184.599, "text": "이야기를 했기 때문에 뭐 매크로"}, {"startSec": 186.72, "text": "전반적인 이제 고객분들이 가장"}, {"startSec": 188.319, "text": "걱정하시는 것들 한번 짚어 드리고"}, {"startSec": 190.599, "text": "여전히 반도체 왜 좋게 보는지 특히"}, {"startSec": 192.56, "text": "어떤 것들 타픽으로 생각하는지 말씀을"}, {"startSec": 194.36, "text": "드린 다음에 사실 저희가 국내 증시만"}, {"startSec": 196.599, "text": "하는게 아니라 해외 주식 전문가분들도"}, {"startSec": 198.599, "text": "많이 계세요. 그래 가지고 그분들도"}, {"startSec": 201.08, "text": "이제 자리를 마련하고 있으니까 그"}, {"startSec": 203.319, "text": "전반적으로 시장을 볼 예정입니다."}, {"startSec": 205.0, "text": "그래서"}, {"startSec": 205.799, "text": "&gt;&gt; 용상 가면 돼요?"}, {"startSec": 206.879, "text": "&gt;&gt; 네. 오시면"}, {"startSec": 208.0, "text": "&gt;&gt; 아 가서 그냥 손수한 PB 찾으면"}, {"startSec": 209.599, "text": "돼요."}, {"startSec": 209.879, "text": "&gt;&gt; 어네 저 찾으시고"}, {"startSec": 211.92, "text": "&gt;&gt; 몇 시 하시는데"}, {"startSec": 212.92, "text": "&gt;&gt; 저희 5시에 진행을 하거든요. 그래서"}, {"startSec": 215.159, "text": "&gt;&gt; 많이 가실 텐데 어떻게 다하시려고"}, {"startSec": 216.439, "text": "그래요?"}, {"startSec": 217.159, "text": "&gt;&gt; 어 최대한 다들 따닥따닥 붙으셔서"}, {"startSec": 220.08, "text": "날씨도 추우니까요."}, {"startSec": 222.0, "text": "&gt;&gt; 에어컨 빵빵에 틀고"}, {"startSec": 223.0, "text": "&gt;&gt; 네. 에어컨 빵빵에 틀고 추우니까"}, {"startSec": 224.64, "text": "따닥따닥 붙어서 같이 시간 보내시면"}, {"startSec": 226.92, "text": "될 것 같습니다."}, {"startSec": 228.04, "text": "&gt;&gt; 아 9,113이면"}, {"startSec": 230.2, "text": "우리가 갑니다."}, {"startSec": 231.12, "text": "&gt;&gt; 어 정말 오실 건가요?"}, {"startSec": 232.64, "text": "&gt;&gt; 9,113이면 종가가"}, {"startSec": 234.319, "text": "&gt;&gt; 네."}, {"startSec": 234.92, "text": "12면 저 빈센트 갈 거고요."}, {"startSec": 236.84, "text": "13이면 제가 갑니다."}, {"startSec": 237.959, "text": "&gt;&gt; 아, 그럼 수급으로 여러분들이 많이"}, {"startSec": 240.439, "text": "도와주시면 좋을 것 같습니다."}, {"startSec": 242.799, "text": "&gt;&gt; 좋습니다. 예."}, {"startSec": 245.0, "text": "&gt;&gt; 자,"}, {"startSec": 245.64, "text": "&gt;&gt; 자, 그래서 뭐 국내 반도체"}, {"startSec": 247.319, "text": "흐름이라든요 거 좀 봐야 되겠죠?"}, {"startSec": 249.04, "text": "지금 분위기는 뭐 매우 좋고."}, {"startSec": 250.959, "text": "하이닉스 삼성전자"}, {"startSec": 253.239, "text": "몇 %입니까, 지금? 어, 10%."}, {"startSec": 255.56, "text": "어 닉스가 10% 조금 안 되네요."}, {"startSec": 257.84, "text": "&gt;&gt; 맞습니다."}, {"startSec": 258.56, "text": "&gt;&gt; 9%쯤 되는 거 같고"}, {"startSec": 260.28, "text": "&gt;&gt; 삼성 전자가 한 5% 약간 안 되게"}, {"startSec": 262.759, "text": "&gt;&gt; 예 가는 거 같네요."}, {"startSec": 263.8, "text": "&gt;&gt; 전자 어제도 많이 올랐으니까 사실"}, {"startSec": 265.6, "text": "이틀 연속 되게 시세를내는 거죠."}, {"startSec": 267.639, "text": "&gt;&gt; 아 그렇죠."}, {"startSec": 269.16, "text": "&gt;&gt; 어제 삼성전자가 한 10% 가까이"}, {"startSec": 271.84, "text": "갔나요?"}, {"startSec": 272.24, "text": "&gt;&gt; 맞습니다."}, {"startSec": 273.16, "text": "&gt;&gt; 네."}, {"startSec": 274.4, "text": "&gt;&gt; 자 그래서 빨리 이제 준비해 주신 거"}, {"startSec": 277.12, "text": "&gt;&gt; 털어 놓으시면 될 것 같은데."}, {"startSec": 278.039, "text": "&gt;&gt; 아 네. 그래서 이제 뭐 장표 보시면"}, {"startSec": 280.0, "text": "AD할 건도 너무 좋았는데 뭐 댓글들"}, {"startSec": 282.56, "text": "제가 기사 난 거 보는데 이제"}, {"startSec": 284.4, "text": "유상증자라는 말에 꽂히셔 가지고 주가"}, {"startSec": 287.4, "text": "떨어지겠네 요런 분들이 많으시고"}, {"startSec": 288.919, "text": "실제로 전화로도 그 공시 자체가"}, {"startSec": 290.6, "text": "유상증자라고 뜨다 보니까 타이틀이"}, {"startSec": 292.72, "text": "고객분들이 이거"}, {"startSec": 294.12, "text": "&gt;&gt; 뭐냐 많이 늘려 주셨는데 걱정하실 거"}, {"startSec": 296.72, "text": "없고요."}, {"startSec": 297.72, "text": "&gt;&gt; 이제 워낙 호재성으로 이미 시장에서"}, {"startSec": 300.28, "text": "받아들여진 내용이기 때문에 뭐"}, {"startSec": 302.4, "text": "긍정적으로 보시면 된다라고 말씀을"}, {"startSec": 304.28, "text": "드리고 있습니다. 그래서 그동안"}, {"startSec": 306.52, "text": "기대감으로 많이 오르기도 했고 뭐"}, {"startSec": 308.56, "text": "ADR은 다들 아신 내용이라 빠르게"}, {"startSec": 310.56, "text": "넘어가고"}, {"startSec": 312.12, "text": "그래서 이제 ADR건도 있고 마이크로"}, {"startSec": 314.32, "text": "실적 발표도 있다 보니까 전닉이냐"}, {"startSec": 316.52, "text": "닉전이냐 이거 제일 많이 물어보시고"}, {"startSec": 318.919, "text": "오면서도 전화한통 받았는데요."}, {"startSec": 320.96, "text": "&gt;&gt; 네. 그래서 이걸 조금 말씀을 드리고"}, {"startSec": 323.36, "text": "싶습니다."}, {"startSec": 324.199, "text": "&gt;&gt; 그니까 보통주 기준으로 시가 총액이"}, {"startSec": 326.039, "text": "다시 역전됐잖아요. 삼성전자가"}, {"startSec": 327.44, "text": "1등이고 스카니트가 2등이고 그래서"}, {"startSec": 329.72, "text": "이제 업치락 뒤치락 하고 있는데 이제"}, {"startSec": 332.16, "text": "제가 생각했을 때는 이제 고객"}, {"startSec": 334.36, "text": "성향별로 이제 저는 둘 다 말씀을"}, {"startSec": 336.28, "text": "드리는 상황이에요. 그래서 이제 저는"}, {"startSec": 338.88, "text": "이제 고객분들께서 비교적 저평가인"}, {"startSec": 342.8, "text": "삼성전자 그러니까 조금 더 든든한 거"}, {"startSec": 345.0, "text": "생 어 좀 생각하신다라고 생각하시면"}, {"startSec": 347.319, "text": "삼성전자 말씀드리고 조금 더 뭔가"}, {"startSec": 349.88, "text": "모멘텀이나 뭐 기대감 쪽으로 견디실"}, {"startSec": 353.44, "text": "수 있는 분들께는 이제 하이닉스를"}, {"startSec": 354.919, "text": "말씀을 드리는 상황입니다. 실제로"}, {"startSec": 357.12, "text": "지금 트렌드 자체가 저평가주보다는"}, {"startSec": 360.199, "text": "가는 말이 더 잘 가는 장세기 때문에"}, {"startSec": 362.6, "text": "그래서 일단은 저는 닉전의 한표를"}, {"startSec": 365.199, "text": "던지는 상황이라고 말씀을 드리고 있는"}, {"startSec": 368.039, "text": "상황입니다. 아"}, {"startSec": 368.479, "text": "&gt;&gt; 닉전이라면 SK닉스 좀 더 비교"}, {"startSec": 370.319, "text": "있다. 뭐"}, {"startSec": 370.759, "text": "&gt;&gt; 지금은 조금 그런 상황이라고"}, {"startSec": 372.68, "text": "생각합니다. ADR도 조금 구체화가"}, {"startSec": 374.599, "text": "됐고 제일 크게 보는 건 제가 여기"}, {"startSec": 376.8, "text": "별표쳐 놓은 HBM 가격 제업"}, {"startSec": 378.919, "text": "상권인데"}, {"startSec": 380.08, "text": "&gt;&gt; 이제"}, {"startSec": 381.16, "text": "&gt;&gt; 이제 연말이랑 내년쯤 해 가지고 가격"}, {"startSec": 384.039, "text": "제상이 있을 예정인데 저는 이게 큰"}, {"startSec": 386.44, "text": "실적 향상 변수로 좀 작용을 할 수"}, {"startSec": 388.72, "text": "있을 거라고 생각을 하거든요."}, {"startSec": 390.12, "text": "&gt;&gt; 음. 음,"}, {"startSec": 390.8, "text": "&gt;&gt; 지금 가격이"}, {"startSec": 393.16, "text": "이제 계속 오르고 있었잖아요. 한"}, {"startSec": 394.52, "text": "네배 정도 오른 거 같은데"}, {"startSec": 396.039, "text": "&gt;&gt; 이게 HBM 같은 경우는 지난해의"}, {"startSec": 398.84, "text": "협상 가격이 지금 팔리고 있는"}, {"startSec": 400.44, "text": "상황이라 사실이 성장률 자체가 반영이"}, {"startSec": 403.72, "text": "안 됐다고 생각하거든요. 애초 HBM"}, {"startSec": 406.0, "text": "자체가 디램을 기반으로 만들었고이"}, {"startSec": 408.199, "text": "디램 공장 할해 HBM에 투자해서"}, {"startSec": 410.759, "text": "만든 상품인데 이거를 딜램만큼"}, {"startSec": 414.36, "text": "오랫만큼 막 더 내놔라 이렇게 할 수"}, {"startSec": 416.479, "text": "없지만 그래도 어 성장분 감안해서 더"}, {"startSec": 419.96, "text": "쳐 줘라 할 수 있는 상황이 있고"}, {"startSec": 421.599, "text": "마이크론에서 이제 뭐"}, {"startSec": 423.0, "text": "&gt;&gt; 네"}, {"startSec": 423.599, "text": "&gt;&gt; 거의 86%면 돈 줘라 한"}, {"startSec": 425.759, "text": "수준이잖아요."}, {"startSec": 427.24, "text": "&gt;&gt; 줘라"}, {"startSec": 427.8, "text": "&gt;&gt; 돈 줘라 이렇게 한 수준인데"}, {"startSec": 429.52, "text": "&gt;&gt; 깡패랑 비싸다. 아, 저 뭐"}, {"startSec": 432.199, "text": "에로샤다. 네. 그래서 뭐 명품백정도"}, {"startSec": 434.879, "text": "되는데 어, HBM 관련해서는 더"}, {"startSec": 438.16, "text": "그럴 수 있는 가능성이 있지"}, {"startSec": 439.84, "text": "않을까라는 생각이 있어서 실적 향상에"}, {"startSec": 442.56, "text": "있어서 전 긍정적으로 보고 있습니다."}, {"startSec": 445.759, "text": "&gt;&gt; 네."}, {"startSec": 446.039, "text": "&gt;&gt; 네. 오늘 선수현 PB가 긴장한"}, {"startSec": 447.919, "text": "이유가 뭐죠?"}, {"startSec": 449.24, "text": "&gt;&gt; 아무래도 세미나가"}, {"startSec": 451.44, "text": "되어 있어서. 네."}, {"startSec": 453.28, "text": "&gt;&gt; 빨리 가."}, {"startSec": 455.96, "text": "&gt;&gt; 빨리 가."}, {"startSec": 457.759, "text": "&gt;&gt; 네. 긴장하고 있구나. 네. 그래서"}, {"startSec": 460.36, "text": "하여튼 뭐 삼성전자 SK 하이닉스"}, {"startSec": 462.759, "text": "좋다 얘기"}, {"startSec": 464.919, "text": "&gt;&gt; 예"}, {"startSec": 465.96, "text": "&gt;&gt; 알겠습니다. 코스닥은 별론가요? 영상"}, {"startSec": 468.36, "text": "&gt;&gt; 아 저번 주에 말씀드렸던 내용이 제가"}, {"startSec": 471.24, "text": "그 코스닥은 이제 장비주 위주로"}, {"startSec": 474.319, "text": "전공정 장비 위주로 그리고 어 소부장"}, {"startSec": 477.52, "text": "위주로 말씀을 드렸었는데네"}, {"startSec": 479.84, "text": "&gt;&gt; 전 여전히 그 뷰는 유지를 하고 있고"}, {"startSec": 482.919, "text": "어제자로 미국도 장비주들 많이"}, {"startSec": 485.56, "text": "긍정적이었기 때문에 저는 국내에서"}, {"startSec": 488.159, "text": "여전히 코스닥 중에 소부장은"}, {"startSec": 490.96, "text": "&gt;&gt; 어 챙겨 가셔도 되겠다라고 생각하고"}, {"startSec": 492.84, "text": "있습니다. 음."}, {"startSec": 493.56, "text": "&gt;&gt; 음."}, {"startSec": 495.319, "text": "&gt;&gt; 그거 준비해 주신 건 다 한한 한"}, {"startSec": 497.08, "text": "거예요?"}, {"startSec": 497.479, "text": "&gt;&gt; 아, 이제 뭐 세미나 관련해 가지고"}, {"startSec": 499.56, "text": "이야기를 좀 드릴게요."}, {"startSec": 500.4, "text": "&gt;&gt; 세미나 안다고 했잖아."}, {"startSec": 502.919, "text": "몇 시에 오면 되는데요?"}, {"startSec": 504.039, "text": "&gt;&gt; 저희 5시에 오시면 돼요. 미리"}, {"startSec": 506.24, "text": "오시면 더 좋고요."}, {"startSec": 507.72, "text": "&gt;&gt; 알겠습니다. 알겠습니다. 좋습니다."}, {"startSec": 509.36, "text": "네."}, {"startSec": 510.199, "text": "&gt;&gt; 자, 나는 또 근데 그 용산 지이 딱"}, {"startSec": 512.88, "text": "하나예요. 그러니까 뭐 우리"}, {"startSec": 514.56, "text": "하나증권에 수많은 지점들이 있죠."}, {"startSec": 516.56, "text": "근데 용산이 가장 젊은 축에 속하죠."}, {"startSec": 519.719, "text": "지험장도 적고. 네. 다들 젊으시고."}, {"startSec": 521.839, "text": "네. 그래서네 지금은 AI 시대"}, {"startSec": 525.2, "text": "우리가 아무도 경험하지 못했기 때문에"}, {"startSec": 527.6, "text": "과거에 틀에서 벗어나서 새로운 시업과"}, {"startSec": 529.64, "text": "새로운 경륜으로 한번"}, {"startSec": 531.64, "text": "&gt;&gt; 관목할 만한 포트폴리오의 수익을 내고"}, {"startSec": 533.72, "text": "있는 용사."}, {"startSec": 534.399, "text": "&gt;&gt; 아, 네. 맞습니다. 저희 BM 대비"}, {"startSec": 536.2, "text": "그러니까 시장 대비해서 지금 수익률"}, {"startSec": 538.399, "text": "따라잡기 굉장히 어려우신데 한"}, {"startSec": 540.6, "text": "50에서 60% 정도 더 랩 자체가"}, {"startSec": 543.839, "text": "상회하고 있어 가지고"}, {"startSec": 544.92, "text": "&gt;&gt; BM이 코스피예요?"}, {"startSec": 546.0, "text": "&gt;&gt; 네. 코스피 코스피"}, {"startSec": 546.88, "text": "&gt;&gt; 코스피 대비 그렇게 아웃품 있어요."}, {"startSec": 548.399, "text": "&gt;&gt; 네."}, {"startSec": 549.519, "text": "정수하고 있셔들어"}, {"startSec": 553.8, "text": "상담 진해시면 더유하실 것 같다는"}, {"startSec": 556.72, "text": "생각이 항상 들어서 이렇게 세미나"}, {"startSec": 558.76, "text": "이야기 많이 드리고 있는 중입니다."}, {"startSec": 560.72, "text": "네네."}, {"startSec": 561.519, "text": "&gt;&gt; 네."}, {"startSec": 562.48, "text": "&gt;&gt; 뭐 세미나 얘기 중에 뭐 미리"}, {"startSec": 564.36, "text": "공개하실 건 없고"}, {"startSec": 565.519, "text": "&gt;&gt; 아. 네. 어제도 저희 용산에서 한번"}, {"startSec": 567.279, "text": "오셔 가지고 간략하게 이야기해 주시긴"}, {"startSec": 569.079, "text": "하셨고 이제 뭐 추가로 조금 더"}, {"startSec": 572.2, "text": "자리를 마련해 두고 있으니까 많이"}, {"startSec": 574.8, "text": "긍정적으로 생각해 주시고 시간 남겨"}, {"startSec": 577.24, "text": "&gt;&gt; 주시면네 알겠습니다. 선착순 원래 다"}, {"startSec": 579.56, "text": "끝났는데 조금 더 열어 주신다는"}, {"startSec": 581.0, "text": "거죠?네"}, {"startSec": 582.68, "text": "&gt;&gt; 오늘 뭐 축구도 이기고 네"}, {"startSec": 584.48, "text": "&gt;&gt; 아 축구 참 있구나 오늘네"}, {"startSec": 585.64, "text": "&gt;&gt; 주가도 올라가고네 더할 나이 없이"}, {"startSec": 587.88, "text": "좋은 날이 되었으면 10시부터"}, {"startSec": 590.079, "text": "축구니까 어디죠? 남화공이라 하나?"}, {"startSec": 592.24, "text": "&gt;&gt; 아,"}, {"startSec": 592.76, "text": "&gt;&gt; 아마도 네. 그랬던 거 같습니다."}, {"startSec": 594.839, "text": "자, 하여튼 우리 오늘 저 가신"}, {"startSec": 597.32, "text": "분들께 정말 좋은 투자의 아이디어들"}, {"startSec": 600.36, "text": "많이 좀 전해 주시고 아, 좋은 결과"}, {"startSec": 602.92, "text": "있으시길 바라겠습니다."}, {"startSec": 604.079, "text": "&gt;&gt; 네. 감사합니다."}, {"startSec": 605.12, "text": "&gt;&gt; 고맙습니다."}, {"startSec": 605.88, "text": "&gt;&gt; 네. 송합니다."}]}