Sec": 178.519, "text": "&gt;&gt; 그러니까 지금 디램이 디램이 예전에"}, {"startSec": 180.879, "text": "엔비디아 같은 주도주가 돼 버린"}, {"startSec": 182.4, "text": "거예요."}, {"startSec": 182.76, "text": "&gt;&gt; 예. 그 마비디아라고 요즘에."}, {"startSec": 184.959, "text": "&gt;&gt; 아 그래요? 마비디아"}, {"startSec": 186.159, "text": "&gt;&gt; 예."}, {"startSec": 187.4, "text": "그거 보면 참 마이크론"}, {"startSec": 191.12, "text": "마이크론이 3이니까 1, 2위인"}, {"startSec": 193.36, "text": "삼성과 하이닉스가 있다는게 참 엄청난"}, {"startSec": 195.48, "text": "대단한 얘기."}, {"startSec": 195.959, "text": "&gt;&gt; 그러니까 지금 하이닉스가 삼성전자보다"}, {"startSec": 198.4, "text": "이렇게 밸류를 더 받는 이유가 미국"}, {"startSec": 200.76, "text": "입성 때문에 그렇습니다."}, {"startSec": 201.799, "text": "&gt;&gt; 음. ADR 상장."}, {"startSec": 202.879, "text": "&gt;&gt; 예. 월 10일 날 정해졌으니까 어제"}, {"startSec": 205.239, "text": "나왔죠. 어제 나왔죠. 속보로."}, {"startSec": 207.319, "text": "&gt;&gt; 예. 그래서 미국 반도체 기업들이"}, {"startSec": 210.08, "text": "시간에서 급등 중인데 어 국내 반도체"}, {"startSec": 213.12, "text": "기업들에게는 2분기 실적에 대한"}, {"startSec": 214.879, "text": "기대감이 증가되는 건다."}, {"startSec": 216.76, "text": "&gt;&gt; 너무 뻔한 얘기를 썼죠. 오늘 참"}, {"startSec": 218.48, "text": "이거 쓰기 너무 편했어. [웃음]"}, {"startSec": 220.76, "text": "&gt;&gt; 근데 요게 주목하셔야 돼. 국채"}, {"startSec": 222.2, "text": "금리가 또 4.3대로. [콧방귀]"}, {"startSec": 223.48, "text": "&gt;&gt; 아 맞아. 오랜만에 시원하게."}, {"startSec": 225.36, "text": "&gt;&gt; 그 얼마나 신났으면 빨간색으로.이"}, {"startSec": 227.942, "text": "[웃음]"}, {"startSec": 229.239, "text": "&gt;&gt; 삼성전자 SK 하이닉스이 호재들"}, {"startSec": 232.079, "text": "때문에 마이크론"}, {"startSec": 233.48, "text": "&gt;&gt; 이것 때문에 오늘 좀 우리가 마음이"}, {"startSec": 235.36, "text": "좀 풀어지네요."}, {"startSec": 236.12, "text": "&gt;&gt; 네. 제가 근데 요거를 준목하는"}, {"startSec": 237.439, "text": "이유가 뭐냐면 어찌 제가 바이오"}, {"startSec": 239.0, "text": "종목들 하루 하루 막 급등했는데 오늘"}, {"startSec": 241.48, "text": "이어질까?"}, {"startSec": 242.68, "text": "&gt;&gt; 음."}, {"startSec": 243.0, "text": "&gt;&gt; 요것 때문에 이어질 수 있을 것"}, {"startSec": 244.12, "text": "같다. 시장 금리가 빠지고 있다."}, {"startSec": 246.0, "text": "&gt;&gt; 그렇지."}, {"startSec": 246.76, "text": "&gt;&gt; 예. 지금 뭐 기준 금리 어쩌고 저쩌"}, {"startSec": 248.519, "text": "얘기하는데 기준 금리 중요하지"}, {"startSec": 249.519, "text": "않아요. 시장 금리가 중요하지."}, {"startSec": 251.159, "text": "&gt;&gt; 음."}, {"startSec": 251.879, "text": "&gt;&gt; 예. 그러니까 그 연준 위원들이 그런"}, {"startSec": 254.92, "text": "말을 하는 경우가 있어요. 아니"}, {"startSec": 257.6, "text": "금리를 올리면 무슨 그니까 시장"}, {"startSec": 261.519, "text": "금리가 높으면"}, {"startSec": 262.88, "text": "&gt;&gt; 기준 금리를 안 올려도"}, {"startSec": 264.96, "text": "&gt;&gt; 알아서 유동성은 마른다."}, {"startSec": 266.759, "text": "&gt;&gt; 음. 그렇죠."}, {"startSec": 267.84, "text": "&gt;&gt; 예. 근데 이제 시장 금리가 조금"}, {"startSec": 269.6, "text": "빠지고 있다. 예. 좋죠. 금리 안"}, {"startSec": 272.0, "text": "내려도 그러면 시장 금리만 내려가면"}, {"startSec": 273.96, "text": "&gt;&gt; 그렇죠."}, {"startSec": 274.6, "text": "&gt;&gt; 예. 좋죠. 예. 그다음에 [콧방귀]"}, {"startSec": 276.8, "text": "어제 외국인들은 뭐 샀냐? 아이고."}, {"startSec": 278.56, "text": "하잉스 팔았네."}, {"startSec": 280.759, "text": "삼성전자도 팔았네."}, {"startSec": 282.308, "text": "&gt;&gt; [웃음]"}, {"startSec": 282.88, "text": "&gt;&gt; 바보들 바보 바보 예"}, {"startSec": 284.88, "text": "&gt;&gt; 오늘 다시 사야지 뭐"}, {"startSec": 286.0, "text": "&gt;&gt; 예 이거 이제 왜 이렇게 팔았냐면"}, {"startSec": 287.199, "text": "이게 이제 연기금 그 글로벌 연기금"}, {"startSec": 289.96, "text": "그다음에 글로벌 펀드들이 분기"}, {"startSec": 292.24, "text": "리밸런싱 하잖아요. 반기 리밸런싱 그"}, {"startSec": 294.68, "text": "자금이라고 보시면 됩니다."}, {"startSec": 296.28, "text": "&gt;&gt; 근데 이제"}, {"startSec": 297.52, "text": "&gt;&gt; 오늘도 올라오면 팔겠죠?"}, {"startSec": 299.56, "text": "&gt;&gt; 그렇죠."}, {"startSec": 300.12, "text": "&gt;&gt; 오늘도 올라오면 팔 아주 땡큐하죠."}, {"startSec": 302.039, "text": "오늘 같은 날은 팔아도 티가 안 나."}, {"startSec": 303.6, "text": "&gt;&gt; 음."}, {"startSec": 304.24, "text": "&gt;&gt; 왜냐면 사는 사람들이 많으니까."}, {"startSec": 305.84, "text": "&gt;&gt; 그렇죠. 오늘 이제 호재들이"}, {"startSec": 307.199, "text": "겹쳤으니까 자신감이 어제는 사실"}, {"startSec": 309.919, "text": "자신감이 없었어요. 우리가이 개인"}, {"startSec": 311.68, "text": "투자자들이 많이 사긴 했어도."}, {"startSec": 313.52, "text": "그러니까 이게 막 심리가 움직여"}, {"startSec": 315.16, "text": "가지고 막 변동성이 너무 심했어."}, {"startSec": 316.96, "text": "어쨌 그러니까 자신감이 없더라고"}, {"startSec": 319.039, "text": "사람들이. 왜냐면 그니까 여러 가지"}, {"startSec": 322.16, "text": "이런 것들이 그 이야기들이 나오면서"}, {"startSec": 325.479, "text": "변동성이 한번 크게 생기고 나면 그때"}, {"startSec": 327.919, "text": "일순간은 좀 꺾이는 거 같아요."}, {"startSec": 329.6, "text": "&gt;&gt; 제가 어제 어제 그저께 종목 추천하는"}, {"startSec": 332.919, "text": "방송을 잘 안 가긴 하는데 몇 개가"}, {"startSec": 334.639, "text": "있어요?"}, {"startSec": 335.88, "text": "가서 뭐 하겠습니까? 제가"}, {"startSec": 337.759, "text": "&gt;&gt; 종목이 없잖아 제가. 그래서 삼성전자"}, {"startSec": 341.258, "text": "[웃음]"}, {"startSec": 343.039, "text": "&gt;&gt; 예 삼성전자를 이틀 동안 수천하고"}, {"startSec": 345.24, "text": "다녔다. 예. 참 성견지명. 음."}, {"startSec": 348.8, "text": "&gt;&gt; 삼성전자 하이닉스 참성전기 삼성"}, {"startSec": 351.12, "text": "기관이 잘했네. 예. 기관이 잘 많이"}, {"startSec": 353.72, "text": "뭐 잘 샀습니다. 어제 외국인들은"}, {"startSec": 356.24, "text": "엉뚱하게 삼성 바이오로직스랑"}, {"startSec": 357.8, "text": "셀트리온을 끌어올렸습니다."}, {"startSec": 359.039, "text": "&gt;&gt; 음."}, {"startSec": 359.56, "text": "&gt;&gt; 네. 근데 요것도 의미가 있을 수"}, {"startSec": 361.0, "text": "있어요. 주가가 많이 빠졌어요."}, {"startSec": 362.68, "text": "얘네들이. 그다음에 코스닥은 양쪽에"}, {"startSec": 365.28, "text": "알테오젠을 제일 많이 샀다. 제가"}, {"startSec": 367.24, "text": "보니까 알테오젠을 왜 샀나 했더니 뭐"}, {"startSec": 369.199, "text": "기술 수출 얘기도 있는데 그게"}, {"startSec": 370.52, "text": "중요한게 아니라 잘하면 알테오젠이"}, {"startSec": 373.12, "text": "코스닥에 남을 수도 있어요."}, {"startSec": 374.319, "text": "&gt;&gt; 음."}, {"startSec": 375.12, "text": "&gt;&gt; 그리고 저거 저 얘기가 나오더라고요."}, {"startSec": 378.319, "text": "그러니까"}, {"startSec": 380.56, "text": "그 그 승강제 만들잖아요."}, {"startSec": 382.479, "text": "&gt;&gt; 네."}, {"startSec": 383.12, "text": "&gt;&gt; 그 RT는 무조건 들어가니까"}, {"startSec": 384.72, "text": "&gt;&gt; 그렇지."}, {"startSec": 385.319, "text": "&gt;&gt; 여기 흑자 기업이잖아."}, {"startSec": 386.759, "text": "&gt;&gt; 음."}, {"startSec": 387.44, "text": "&gt;&gt; 예. 이게 이게 거기에 대장이 될 수"}, {"startSec": 390.08, "text": "있다."}, {"startSec": 391.16, "text": "&gt;&gt; 그렇죠. 지금도 뭐 시총 1이"}, {"startSec": 392.72, "text": "아니에요. 예. 1인데 1인데"}, {"startSec": 394.84, "text": "&gt;&gt; 사실 상위권 종목들이 거의 많이 다"}, {"startSec": 396.68, "text": "편입되겠죠."}, {"startSec": 397.52, "text": "&gt;&gt; 예. 근데 상위권 안에서도 바이오"}, {"startSec": 399.759, "text": "종목 중에는 일부 떨어지는 종목이"}, {"startSec": 402.36, "text": "&gt;&gt; 예. 있을 있 있을 예. 있을"}, {"startSec": 403.84, "text": "겁니다."}, {"startSec": 405.24, "text": "&gt;&gt; 어. 그리고 오늘은 예. 또 때마침"}, {"startSec": 408.639, "text": "제가 또네 SK하이닉스를 갖고"}, {"startSec": 410.479, "text": "나왔네."}, {"startSec": 410.88, "text": "&gt;&gt; 음."}, {"startSec": 411.68, "text": "&gt;&gt; 28년까지 공국 부족 지속될"}, {"startSec": 413.44, "text": "전망이다."}, {"startSec": 414.28, "text": "&gt;&gt; 네."}, {"startSec": 414.88, "text": "&gt;&gt; 누가 쓰신 거냐? 제가 좋아하는"}, {"startSec": 417.28, "text": "존경하는 녹은창 연태장님이."}, {"startSec": 419.08, "text": "&gt;&gt; 음."}, {"startSec": 420.4, "text": "직접 친히 쓰셨죠. 근데 목표가"}, {"startSec": 422.8, "text": "330만 원 좀 짜다."}, {"startSec": 426.319, "text": "&gt;&gt; 근데 이분은 그"}, {"startSec": 427.96, "text": "&gt;&gt; 좀 보수적으로 보는 분이라"}, {"startSec": 429.479, "text": "&gt;&gt; 예. 이게 보니까 7점 26년"}, {"startSec": 433.12, "text": "예상치에 PER 7.6배 그다음에"}, {"startSec": 436.319, "text": "26년 예상 PBR 이거를 섞었어요."}, {"startSec": 439.72, "text": "산술 평균에서 265만 원이라고"}, {"startSec": 441.879, "text": "예전에 내보냈는데 어 다시 해 보니깐"}, {"startSec": 445.44, "text": "8.5배 4.5배, 4.6배를까진"}, {"startSec": 447.599, "text": "올려도 될 거 같다. 그래서 330만"}, {"startSec": 450.0, "text": "원 이렇게 얘기를 했습니다. 그래서"}, {"startSec": 452.36, "text": "어 이게 이제 금액 요거 자꾸 TP를"}, {"startSec": 454.72, "text": "보세요. 사람들이 금액을 금액이"}, {"startSec": 457.4, "text": "아니라 논리를 봐야 됩니다."}, {"startSec": 459.319, "text": "&gt;&gt; 아 이분이 아직은"}, {"startSec": 461.24, "text": "&gt;&gt; 그게 사이클이긴 사이클인데 그래도"}, {"startSec": 463.56, "text": "밸류를 좀 더 줘야 될 거 같기도"}, {"startSec": 465.08, "text": "하고 이런 거예요, 지금."}, {"startSec": 466.199, "text": "&gt;&gt; 음."}, {"startSec": 466.72, "text": "&gt;&gt; 음. 혼란에 빠지셨습니다."}, {"startSec": 468.28, "text": "&gt;&gt; 네."}, {"startSec": 469.0, "text": "&gt;&gt; 예. 그 PB PR P.5 준게"}, {"startSec": 471.599, "text": "아니라 PBR이랑 산술 평균을 했다는"}, {"startSec": 474.12, "text": "거예요."}, {"startSec": 474.479, "text": "&gt;&gt; 음. 음. 요렇게도 구해하고 저렇게도"}, {"startSec": 477.039, "text": "구해 봤더니요 정도 가격 요걸로 하면"}, {"startSec": 479.72, "text": "많이 나오겠죠?"}, {"startSec": 481.159, "text": "&gt;&gt; 요걸로 하면 좀 적게 나올 거"}, {"startSec": 482.24, "text": "아니에요. 그곧 중간값을 정했다."}, {"startSec": 484.96, "text": "이렇게 딱 얘기해. 마이크론의 대비"}, {"startSec": 486.919, "text": "10% 할인했다."}, {"startSec": 489.879, "text": "&gt;&gt; 근데 이제 10% 할인할 필요가"}, {"startSec": 492.12, "text": "없잖아. ADR 상장이 되면."}, {"startSec": 493.4, "text": "&gt;&gt; ADR 상장해도 10% 할인합니다."}, {"startSec": 495.0, "text": "해야 됩니다."}, {"startSec": 495.4, "text": "&gt;&gt; 아, 그래야 된다."}, {"startSec": 496.28, "text": "&gt;&gt; 왜냐면 그 마이크로는 주주 환원이"}, {"startSec": 499.199, "text": "굉장히 세죠."}, {"startSec": 499.96, "text": "&gt;&gt; 아, 세긴 하지. 음."}, {"startSec": 501.24, "text": "&gt;&gt; 네. 그런 걸 이제 감안하면 약간"}, {"startSec": 503.039, "text": "정도의 할인은 나올 수 있다."}, {"startSec": 504.52, "text": "&gt;&gt; 네. 물론 이제 막상 갔는데 시장에서"}, {"startSec": 507.919, "text": "SK닉스를 좋아해서 그 수급이 막"}, {"startSec": 510.12, "text": "들어와 가지고 일시적으로 예."}, {"startSec": 512.36, "text": "마이크론보다 밸류가 더 나갈 수도"}, {"startSec": 513.8, "text": "있습니다."}, {"startSec": 514.279, "text": "&gt;&gt; 음."}, {"startSec": 514.919, "text": "&gt;&gt; 예. 그럼 그런 거는 뭐 근데"}, {"startSec": 517.399, "text": "이론적으로는 10% 정도는 할인"}, {"startSec": 519.36, "text": "받는게 맞는 거죠."}, {"startSec": 520.519, "text": "&gt;&gt; 근데 생각에 그냥 쏠리면은 그냥 어"}, {"startSec": 523.159, "text": "실적 보면 그냥 이쪽으로 갈 것"}, {"startSec": 524.88, "text": "같아. SK 하이닉스로 그쪽도"}, {"startSec": 526.56, "text": "미국에서도"}, {"startSec": 527.48, "text": "&gt;&gt; 그니까 마이크로 실적 보니깐 랜드가"}, {"startSec": 530.64, "text": "뭐 거 이상 올랐더라 가격이."}, {"startSec": 532.399, "text": "&gt;&gt; 음."}, {"startSec": 533.2, "text": "&gt;&gt; 전분기 대비. 그리고이"}, {"startSec": 536.399, "text": "디램이 한 60몇 %"}, {"startSec": 538.12, "text": "&gt;&gt; 아 많이 그러니까 지난번 녹은창"}, {"startSec": 540.88, "text": "센터장이 그 얘기하더라고 1분기는"}, {"startSec": 543.079, "text": "전분기 대비에서 100% 올랐지만이"}, {"startSec": 545.0, "text": "100%인가 그렇지 1분기 대비"}, {"startSec": 547.2, "text": "2분기는 또 60% 올랐다고네"}, {"startSec": 549.44, "text": "&gt;&gt; 더 올 것 같습니다."}, {"startSec": 550.88, "text": "&gt;&gt; 음"}, {"startSec": 551.56, "text": "&gt;&gt; 그니까이 쇼티지가 계속 갈 거"}, {"startSec": 552.88, "text": "같아요."}, {"startSec": 553.24, "text": "&gt;&gt; 그러니까 60% 예상했는데 한 70"}, {"startSec": 555.44, "text": "그니까 평균에 보면 한 70% 가까이"}, {"startSec": 558.04, "text": "예 그럴 것 같습니다. 지금 다시"}, {"startSec": 559.8, "text": "그래서 열심히 체하 60% 이상은"}, {"startSec": 562.72, "text": "써야 되잖아요. 그렇죠."}, {"startSec": 564.44, "text": "&gt;&gt; 어, 지금 애널리스트도 이제"}, {"startSec": 566.079, "text": "바빠졌습니다. 이제 또 이제 오늘"}, {"startSec": 568.04, "text": "열심히"}, {"startSec": 568.56, "text": "&gt;&gt; 목표가 상향시켜야지. 또"}, {"startSec": 569.76, "text": "&gt;&gt; 열심히 써 가지고 예. 빠른 사람은"}, {"startSec": 572.959, "text": "내일"}, {"startSec": 573.64, "text": "&gt;&gt; 음."}, {"startSec": 574.079, "text": "&gt;&gt; 늦는 사람은 월"}, {"startSec": 576.959, "text": "&gt;&gt; 예. 주말에 일해야 돼. 예. SDI"}, {"startSec": 581.32, "text": "&gt;&gt; 어, 요거 요거 쓰신 분이 2차전지"}, {"startSec": 583.519, "text": "이한나 기 연구원이 썼는데 어,"}, {"startSec": 587.24, "text": "이분이 배종성 씨랑 요거는 이제 여기"}, {"startSec": 589.48, "text": "아래죠. 예."}, {"startSec": 591.279, "text": "씨가 이제 메인인데이 차지 다"}, {"startSec": 593.76, "text": "썼어요. 다 썼는데 제가 SDI만"}, {"startSec": 595.68, "text": "갖고 나온 겁니다."}, {"startSec": 596.44, "text": "&gt;&gt; 음."}, {"startSec": 596.839, "text": "&gt;&gt; 예. 목표가 목표 주가"}, {"startSec": 598.399, "text": "91만3,000원."}, {"startSec": 599.959, "text": "아무래도 뭐 전고체"}, {"startSec": 602.04, "text": "&gt;&gt; 전고체도 있고 여기 보면은 뭐 EV도"}, {"startSec": 605.8, "text": "회복되고 있고 그다음에 뿌 있잖아."}, {"startSec": 608.0, "text": "BBU UPS용 BBU 데이터 센터"}, {"startSec": 610.72, "text": "이거 좋고 어 ES 3분기부터 흑자"}, {"startSec": 614.24, "text": "전환도 가능하다. 4분기에는 LFP"}, {"startSec": 617.48, "text": "ESC 초기 양산에 들어가기"}, {"startSec": 619.36, "text": "시작한다. 예. 이러면서 이제"}, {"startSec": 621.24, "text": "이익률이 급격하게 개선될 거다. 이제"}, {"startSec": 623.44, "text": "이런 거를 한 6개월치를 당겨 준"}, {"startSec": 625.32, "text": "거죠."}, {"startSec": 626.92, "text": "가지고 내년 정도 실적까지 감안했을"}, {"startSec": 629.519, "text": "때는 한 91만 원도 가능하다. 이런"}, {"startSec": 631.24, "text": "내용이었어요. 그래서"}, {"startSec": 633.0, "text": "&gt;&gt; 어이 차지 하나 살 거면 SDI"}, {"startSec": 636.12, "text": "사시는게 맞다. 예. 뭐 LG 앤솔도"}, {"startSec": 640.0, "text": "좋게 썼습니다. 예. 예."}, {"startSec": 642.24, "text": "&gt;&gt; LNF 부도소 쓰셨고 예. 한번"}, {"startSec": 644.16, "text": "찾아보세요. 그러니까 이게 업종"}, {"startSec": 646.959, "text": "리포트를 오랜만에 쓴 겁니다."}, {"startSec": 648.839, "text": "&gt;&gt; 어제 어젠가 보니까 그 중국에서 리튬"}, {"startSec": 652.24, "text": "탄산 리튬 가격이 갑자기 반등하기"}, {"startSec": 654.12, "text": "시작하 그게"}, {"startSec": 655.32, "text": "&gt;&gt; 그거는 지금 계속 꾸준히 올라오고"}, {"startSec": 656.839, "text": "있습니다. 예."}, {"startSec": 657.32, "text": "&gt;&gt; 음. 좀 빠지다가 이렇게 다시"}, {"startSec": 658.639, "text": "올라오고 있어요. 지금"}, {"startSec": 659.68, "text": "&gt;&gt; 네. 지금 시가 지금 프리마켓에서는"}, {"startSec": 662.48, "text": "삼성전자가 6%, 하이닉스가 10%"}, {"startSec": 664.92, "text": "이것도 시총 1위를 또 역전당할 수도"}, {"startSec": 666.92, "text": "있는"}, {"startSec": 667.72, "text": "&gt;&gt; 오늘 뭐 예"}, {"startSec": 669.279, "text": "&gt;&gt; 박빙의 승부가 예상됩니다. 예."}, {"startSec": 671.88, "text": "&gt;&gt; 이게 지금 미국 상장할 거에 대한"}, {"startSec": 674.2, "text": "밸류를 반영해서 자꾸 먼저 올라가는"}, {"startSec": 675.959, "text": "거거든요."}, {"startSec": 676.8, "text": "&gt;&gt; 예. 그러니까"}, {"startSec": 678.36, "text": "&gt;&gt; 지금 ADR 상장 이슈를 제가 안"}, {"startSec": 680.6, "text": "쓰긴 했는데 ADR 상장 이슈가 있기"}, {"startSec": 682.279, "text": "때문에 이게 어제 발표가 났잖아요."}, {"startSec": 684.279, "text": "장 끝나고. 그래서 이제 시간"}, {"startSec": 685.839, "text": "외에서도 어 프리 그깐 후장에서도 좀"}, {"startSec": 689.88, "text": "올라갔죠."}, {"startSec": 690.92, "text": "&gt;&gt; 예. 갑자기 막 올라가더라고. 그래서"}, {"startSec": 692.6, "text": "왜 그러나 했더니 그러니까 그거 왜"}, {"startSec": 694.839, "text": "안 나오냐고 저한테 막 따지더라고"}, {"startSec": 696.399, "text": "사람들이. 왜 따지는 거야 나한테?"}, {"startSec": 698.892, "text": "[콧방귀]"}, {"startSec": 699.548, "text": "[웃음]"}, {"startSec": 700.079, "text": "그 SEC한테 물어봐."}, {"startSec": 702.36, "text": "&gt;&gt; 저기 그 뭐 뭐 모든 거는 다 그냥"}, {"startSec": 705.6, "text": "이건희 대표한테다 따지는 거지."}, {"startSec": 707.24, "text": "&gt;&gt; 예. 그러니까 예."}, {"startSec": 708.68, "text": "&gt;&gt; 아니 그 이게 우리가 진짜이"}, {"startSec": 710.16, "text": "외국인들이 받아내는 물량을 다"}, {"startSec": 712.0, "text": "받아내는데 우리 개인들이."}, {"startSec": 713.639, "text": "&gt;&gt; 예. 아 하여튼 이것이 구조적으로"}, {"startSec": 716.959, "text": "계속 좀 이렇게 유지되기 위해서 계속"}, {"startSec": 719.76, "text": "올라가기 위해서는 하여튼 나중에이"}, {"startSec": 722.44, "text": "MSC의 선진국 지수 빨리 좀 해야"}, {"startSec": 724.519, "text": "될 거 같아. 그래서이 외국인들이"}, {"startSec": 726.279, "text": "물량을 또 받아가게"}, {"startSec": 727.639, "text": "&gt;&gt; 내년에 되겠죠. 예. 올해 아마"}, {"startSec": 730.959, "text": "요렇게 됐으니까"}, {"startSec": 731.839, "text": "&gt;&gt; 그것또 내 후년이나 돼야지 MSCI에"}, {"startSec": 734.16, "text": "들어간다. 예. 그러면 이미 한"}, {"startSec": 736.16, "text": "12,000 포인트 이상가 있을 것"}, {"startSec": 737.639, "text": "같은데."}, {"startSec": 738.56, "text": "&gt;&gt; 예."}, {"startSec": 739.639, "text": "&gt;&gt; 그때 만약 들어와서 사가 주면"}, {"startSec": 741.12, "text": "&gt;&gt; 어 예. 그때 아주 비싼 가격에 좀"}, {"startSec": 742.88, "text": "사가 사가야죠."}, {"startSec": 744.72, "text": "&gt;&gt; 아유, 좋다."}, {"startSec": 746.708, "text": "[웃음]"}, {"startSec": 747.12, "text": "&gt;&gt; 그렇게 되면 다행인데."}, {"startSec": 748.12, "text": "&gt;&gt; 어, 그렇죠. 예. 예. 걔네들한테"}, {"startSec": 750.44, "text": "없고 나오셔. [웃음]"}, {"startSec": 752.72, "text": "예. 그래서 지금 뭐 미국 기관들"}, {"startSec": 756.04, "text": "스페이스엑스 다 샀다가 지금"}, {"startSec": 757.24, "text": "망했잖아요. 예. 예. 그"}, {"startSec": 761.0