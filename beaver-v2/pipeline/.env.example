# 복사해서 .env 로 만들고 값 채우기. run.sh 가 자동 로드함.
# 둘 다 구글에서 무료로 발급 가능.
YOUTUBE_API_KEY=여기에_유튜브_데이터_API_키
# 선택: 공공데이터포털 KRX 상장종목정보 API 키
KRX_API_KEY=여기에_공공데이터포털_API_키
# local-first: Ollama 우선, 실패 시 Gemini / ollama: 로컬만 / gemini: Gemini만
ANALYSIS_PROVIDER=local-first
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:14b
OLLAMA_TIMEOUT_SECONDS=300
MAX_ANALYZED_VIDEOS=10
SEARCH_LOOKBACK_DAYS=14
SEARCH_MAX_VIDEOS_PER_CHANNEL=5
SEARCH_MAX_YOUTUBERS=10
# 로컬 실패 시 fallback용(선택)
GEMINI_API_KEY=여기에_제미나이_API_키
SUPADATA_API_KEY=여기에_Supadata_자막_API_키
# 선택: 모델 변경
GEMINI_MODEL=gemini-1.5-flash
# 실패한 자막을 다시 시도하기까지 기다릴 시간
TRANSCRIPT_FAILURE_TTL_HOURS=12
# 자막 제공처 요청 사이의 최소 간격
TRANSCRIPT_REQUEST_DELAY_SECONDS=1.0
# 필요할 때만 1로 설정해 캐시를 무시
FORCE_TRANSCRIPT_REFRESH=0
FORCE_ANALYSIS_REFRESH=0
